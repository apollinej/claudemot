{
  "manifest_version": 3,
  "name": "Claudemot",
  "version": "0.1.0",
  "description": "Claudemot — Annotate Claude.ai conversations like a textbook. Highlights, notes, and insights sync to Notion.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://api.notion.com/*",
    "https://fonts.googleapis.com/*",
    "https://fonts.gstatic.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/chat/*"],
      "js": ["content/content-script.js"],
      "css": ["assets/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "annotate": {
      "suggested_key": {
        "default": "Ctrl+Shift+A",
        "mac": "Command+Shift+A"
      },
      "description": "Annotate selected text"
    },
    "toggle-sidebar": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Toggle annotations sidebar"
    }
  }
}
